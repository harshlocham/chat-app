{
    "globalEnv": [
        "MONGODB_URI",
        "ACCESS_TOKEN_SECRET",
        "REFRESH_TOKEN_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "IMAGEKIT_PRIVATE_KEY",
        "IMAGEKIT_PUBLIC_KEY",
        "INTERNAL_SECRET",
        "ORIGIN",
        "REDIS_URL",
        "SOCKET_SERVER_URL",
        "SMTP_*",
        "EMAIL_*",
        "NEXT_PUBLIC_*"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "dist/**"
            ]
        },
        "dev": {
            "cache": false
        },
        "start": {
            "dependsOn": [
                "build",
                "^build"
            ],
            "cache": false
        },
        "lint": {},
        "clean": {
            "cache": false
        }
    }
}