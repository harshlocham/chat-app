{
  "name": "chat-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "typecheck": "npx tsc --noEmit && npm run typecheck --workspace @chat/web && npm run typecheck --workspace @chat/socket",
    "ci:verify-artifacts": "bash ./scripts/ci/verify-artifacts.sh",
    "security:audit": "npm audit --omit=dev --audit-level=high"
  },
  "devDependencies": {
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20",
    "@types/express": "^5.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/nodemailer": "^7.0.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "eslint-plugin-import": "^2.32.0",
    "@eslint/eslintrc": "^3",
    "tailwindcss": "^4.1.11",
    "@tailwindcss/postcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.4"
  }
}